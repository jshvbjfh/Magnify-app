						// Update existing item
						const updatedItem = await prisma.inventoryItem.update({
							where: { id: existingItem.id },
							data: {
								unit: item.unit,
								unitPrice: item.unitPrice !== undefined ? (item.unitPrice || null) : existingItem.unitPrice,
								quantity: item.quantity !== undefined ? item.quantity : existingItem.quantity,
								category: item.category || existingItem.category
							} as any
						})
						createdItems.push({ name: updatedItem.name, updated: true })
					} else {
						// Create new item
						const newItem = await prisma.inventoryItem.create({
							data: {
								userId,
								name: item.name,
								unit: item.unit,
								unitPrice: item.unitPrice || null,
								quantity: item.quantity || 0,
								category: item.category || null
							} as any
						})
						createdItems.push({ name: newItem.name, updated: false })
					}
				}

				return NextResponse.json({
					response: parsedResponse.message || 'Inventory item(s) added successfully!',
					itemsCreated: createdItems
				})
			}

			// Regular response
			return NextResponse.json({ response: responseText })
		} catch (e: any) {
			lastError = e
			continue
		}

		throw lastError || new Error('All AI models failed')
	} catch (e: any) {
		console.error('AI chat error:', e)
		// Return a user-friendly error message instead of technical details
		return NextResponse.json({ 
			response: "I'm sorry, I encountered an issue processing your request. Could you please try rephrasing your question or try again in a moment?" 
		}, { status: 200 })
	}
}
