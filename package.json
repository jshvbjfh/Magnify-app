{
  "name": "restaurant-app",
  "version": "0.1.0",
  "description": "Magnify — Restaurant Management",
  "author": "Magnify",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "prisma:prepare": "node scripts/prepare-prisma-schema.mjs",
    "prisma:generate": "npm run prisma:prepare && prisma generate --schema prisma/schema.generated.prisma",
    "build": "npm run prisma:generate && next build",
    "build:electron": "npm run prisma:generate && cross-env BUILD_TARGET=electron next build && node scripts/copy-standalone.mjs",
    "start": "next start -p $PORT -H 0.0.0.0",
    "postinstall": "npm run prisma:generate",
    "electron": "npm run build:electron && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:build": "npm run build:electron && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.468.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.11",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.magnify.restaurant",
    "productName": "Magnify",
    "copyright": "Copyright © 2026 Magnify",
    "asar": true,
    "extraFiles": [
      {
        "from": "node_modules/.prisma",
        "to": "resources/app/node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "electron/",
      "prisma/",
      "public/",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/**/*",
      "package.json",
      "next.config.js",
      "next-env.d.ts",
      "tsconfig.json",
      "postcss.config.js",
      "tailwind.config.ts",
      ".env",
      ".next/**/*",
      ".next/standalone/node_modules/**/*",
      "app/**/*",
      "components/**/*",
      "contexts/**/*",
      "lib/**/*",
      "types/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Magnify",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "en_US"
      ]
    },
    "forceCodeSigning": false,
    "asarUnpack": [
      "**/*.node",
      ".next/standalone/**",
      ".next/standalone/node_modules/**"
    ]
  }
}
